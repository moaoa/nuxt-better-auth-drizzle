# Database
DATABASE_URL="postgresql://user:password@localhost:5432/dbname"

# Notion OAuth
NOTION_OAUTH_CLIENT_ID="your-client-id"
NOTION_CLIENT_SECRET="your-client-secret"
NOTION_REDIRECT_URI="http://localhost:3000/auth/notion/callback"

# Auth
AUTH_SECRET="your-auth-secret"
AUTH_ORIGIN="http://localhost:3000"

# Node Environment
NODE_ENV="development"

# PostHog Cloud (optional — enables @posthog/nuxt when NUXT_PUBLIC_POSTHOG_KEY is set)
# Project API key: PostHog → Project settings. Host defaults to US Cloud; use https://eu.i.posthog.com for EU.
# NUXT_PUBLIC_POSTHOG_KEY="phc_..."
# NUXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"