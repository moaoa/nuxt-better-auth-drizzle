COMPOSE_FILE=docker-compose.yml:docker-compose.dev.yml

# PostgreSQL Database Configuration
# These variables are used by docker-compose.prod.yml to create and configure the PostgreSQL database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=phone_call_app_db

# Database Connection Configuration
# The application will construct the connection URL from these separate variables.
# For docker-compose: use 'postgres' as the hostname (service name)
# For local development: use 'localhost' or '127.0.0.1' as the hostname
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=phone_call_app_db

# Legacy DATABASE_URL (optional - will be used if provided, otherwise constructed from DB_* variables above)
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
# Example for docker-compose:
#   DATABASE_URL=postgres://postgres:your_secure_password_here@postgres:5432/phone_call_app_db
# Example for local development (if connecting from host, use port 5433 as mapped in docker-compose.yml):
#   DATABASE_URL=postgres://postgres:your_secure_password_here@localhost:5433/phone_call_app_db
# DATABASE_URL=postgres://postgres:your_secure_password_here@postgres:5432/phone_call_app_db

NUXT_SESSION_PASSWORD=f04d76e91cca40e78ba6d4926e506703
# Turso
NUXT_TURSO_DATABASE_URL=
NUXT_TURSO_AUTH_TOKEN="12312312"
# DOCKER COMPOSER DB OPTIONAL IF YOU WANT TO HOST IT LOCALLY OR ON coolify
## NUXT_TURSO_DATABASE_URL=http://localhost:8080
## NUXT_TURSO_AUTH_TOKEN=<GENERATE A LOCAL TOKEN>

# Better Auth
BETTER_AUTH_SECRET=lJLBAEJke0WjRpehRB1yUNBsArQxCxws
BETTER_AUTH_URL=http://localhost:3000
NUXT_BETTER_AUTH_URL=http://localhost:3000

# Email
MAILGUN_API_KEY=<TOKEN>
MAILGUN_DOMAIN=<DOMAIN>
MAIL_FROM_EMAIL=<Email from example no-reply@domain.com>

# Google Auth
GOOGLE_CLIENT_ID=<Client ID>
GOOGLE_CLIENT_SECRET=<Client Secret>

# Twilio (for browser calling)
TWILIO_ACCOUNT_SID=<Your Account SID>
TWILIO_AUTH_TOKEN=<Your Auth Token>
TWILIO_PHONE_NUMBER=<Your Twilio Phone Number>
TWILIO_WEBHOOK_SECRET=<Webhook Secret for signature validation>

# REQUIRED for browser-to-phone calls: Create a TwiML App in Twilio Console
# https://console.twilio.com/us1/develop/runtime/twiml-apps
# Set the Voice URL to: https://yourdomain.com/api/twilio/voice
TWILIO_APP_SID=<TwiML App SID (starts with AP)>

# Optional: Create API Key in Twilio Console for better security (recommended)
# If not provided, TWILIO_AUTH_TOKEN will be used for token signing
# TWILIO_API_KEY_SID=<API Key SID (starts with SK)>
# TWILIO_API_KEY_SECRET=<API Key Secret>

# Twilio Webhook Base URL (auto-set by scripts/start-zrok.sh when using zrok tunnel)
TWILIO_WEBHOOK_BASE_URL=<Your zrok or public URL, e.g. https://abc123.share.zrok.io>

# Call Profit Margin (as decimal, e.g., 0.50 = 50% margin)
CALL_PROFIT_MARGIN=0.50